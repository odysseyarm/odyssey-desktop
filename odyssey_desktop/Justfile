# Build first with: dx build --release
# vpk packs the dx app dir directly (exe + assets); velopack generates its own
# Setup.exe / portable zip, so no MSI/NSIS bundling is involved.
# channel: stable | beta | nightly  (velopack channel = win-x64-<channel>).
# version: overrides the version read from Cargo.toml. For nightly, the default
#          is the Cargo.toml base version plus -nightly.<yyyyMMdd>.
# token:   GitHub token for the delta download; falls back to $env:GITHUB_TOKEN.
velopack channel='stable' version='' token='':
    #!pwsh
    Set-StrictMode -Version Latest
    $ErrorActionPreference = 'Stop'

    $channel = '{{channel}}'
    if ($channel -notin @('stable','beta','nightly')) {
        Write-Error "Invalid channel '$channel' (expected stable, beta or nightly)"; exit 1
    }
    $token = '{{token}}'
    if (-not $token) { $token = $env:GITHUB_TOKEN }
    $vpkChannel = "win-x64-$channel"

    # --- paths / ids ---
    $packDir  = Join-Path $PWD.Path '..\target\dx\odyssey_desktop\release\windows\app'
    $packId   = 'Odyssey.Desktop'
    $mainExe  = 'odyssey_desktop.exe'

    if (-not (Test-Path (Join-Path $packDir $mainExe))) {
        Write-Error "No app at $packDir (run: dx build --release)"; exit 1
    }

    # version from Cargo.toml (keeps prerelease suffixes like 0.5.0-beta.1)
    $packVersion = (Select-String -Path 'Cargo.toml' -Pattern '^version = "(.+)"').Matches[0].Groups[1].Value
    if ('{{version}}') {
        $packVersion = '{{version}}'
    } elseif ($channel -eq 'nightly') {
        $packVersion = "$($packVersion.Split('-')[0])-nightly.$(Get-Date -Format yyyyMMdd)"
    }

    # fetch previous packages for this channel so vpk pack can build deltas
    $dl = @('--repoUrl', 'https://github.com/odysseyarm/odyssey-desktop', '--channel', $vpkChannel)
    if ($channel -ne 'stable') { $dl += '--pre' }
    if ($token) { $dl += @('--token', $token) }
    vpk download github @dl

    Write-Host "Packing Velopack:"
    Write-Host "  packId     = $packId"
    Write-Host "  version    = $packVersion"
    Write-Host "  packDir    = $packDir"
    Write-Host "  mainExe    = $mainExe"
    Write-Host "  channel    = $vpkChannel"

    vpk pack --packId $packId --packVersion $packVersion --packDir $packDir --mainExe $mainExe --channel $vpkChannel

    Write-Output "Velopack built for $packId $packVersion (dir=$packDir, exe=$mainExe, channel=$vpkChannel)"

# Publish the packed channel to the GitHub release tagged odyssey-desktop-v<version>.
# version defaults to Cargo.toml (with -nightly.<yyyyMMdd> appended for nightly,
# matching the velopack recipe). token falls back to $env:GITHUB_TOKEN.
# beta/nightly releases get the GitHub prerelease flag. --merge lets a second
# channel attach to an existing tag.
release channel version='' token='':
    #!pwsh
    Set-StrictMode -Version Latest
    $ErrorActionPreference = 'Stop'

    $channel = '{{channel}}'
    if ($channel -notin @('stable','beta','nightly')) {
        Write-Error "Invalid channel '$channel' (expected stable, beta or nightly)"; exit 1
    }
    $version = '{{version}}'
    if (-not $version) {
        $version = (Select-String -Path 'Cargo.toml' -Pattern '^version = "(.+)"').Matches[0].Groups[1].Value
        if ($channel -eq 'nightly') {
            $version = "$($version.Split('-')[0])-nightly.$(Get-Date -Format yyyyMMdd)"
        }
    }
    $token = '{{token}}'
    if (-not $token) { $token = $env:GITHUB_TOKEN }
    if (-not $token) { Write-Error 'No token: pass one (just release <channel> <version> <token>) or set GITHUB_TOKEN'; exit 1 }

    $uploadArgs = @(
        '--repoUrl', 'https://github.com/odysseyarm/odyssey-desktop',
        '--token', $token,
        '--channel', "win-x64-$channel",
        '--releaseName', "Odyssey Desktop v$version",
        '--tag', "odyssey-desktop-v$version",
        '--publish',
        '--merge'
    )
    if ($channel -ne 'stable') { $uploadArgs += '--pre' }

    vpk upload github @uploadArgs
