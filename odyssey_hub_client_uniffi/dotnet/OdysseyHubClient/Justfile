set shell := ["powershell.exe", "-c"]

build: build_lib build_projects
run: build run_only

# One-time setup. The uniffi-bindgen-cs tag must match the uniffi crate
# version in ../../Cargo.toml (tag format: v<tool>+v<uniffi>).
install_tools:
  cargo install uniffi-bindgen-cs --git https://github.com/NordSecurity/uniffi-bindgen-cs --tag v0.11.0+v0.31.0

build_lib:
  Write-Host 'OdysseyHubClient' -ForegroundColor Blue;
  Write-Host 'Building native library (Rust)' -ForegroundColor Cyan;
  cargo build --manifest-path=../../Cargo.toml -r --target=x86_64-pc-windows-msvc;
  cargo run --manifest-path=../../Cargo.toml -r --bin cs_bindgen -- ../../target/x86_64-pc-windows-msvc/release/ohc_uniffi.dll OdysseyHubClient/generated
  & (Get-Process -Id $PID).Path { \
    $env:CROSS_CONFIG="../../Cross.toml"; \
    cross build --manifest-path=../../Cargo.toml -r --target=x86_64-unknown-linux-gnu; \
    cross build --manifest-path=../../Cargo.toml -r --target=aarch64-unknown-linux-gnu; \
  }

build_projects:
  Write-Host 'Building OdysseyArm.HubClient' -ForegroundColor Cyan;
  dotnet build .\OdysseyHubClient\ -c Release;
  dotnet pack .\OdysseyHubClient\ -o nugets;

  Write-Host 'Publishing OdysseyArm.HubClient.Test' -ForegroundColor Cyan;
  dotnet build .\OdysseyHubClient.Test\;
  dotnet publish .\OdysseyHubClient.Test\ -o .\output;

  Write-Host 'Running published OdysseyArm.HubClient.Test' -ForegroundColor Cyan;
  Write-Host;

run_only:
  ./output/OdysseyArm.HubClient.Test.exe
